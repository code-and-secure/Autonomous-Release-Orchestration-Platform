{
  "title": "Release Health Overview",
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "Pod Restart Count",
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_restarts_total{namespace=~\"dev|prod\"})"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Success Rate",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"2..\"}[5m])) / sum(rate(http_requests_total[5m]))"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
